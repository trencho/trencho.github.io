{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://trencho.github.io/",
  "type": "module",
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae",
  "scripts": {
    "predeploy": "yarn build",
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "build": "tsc -noEmit && vite build && vite build --ssr src/entry-server.tsx --outDir dist-ssr && node scripts/prerender.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emailjs/browser": "4.4.1",
    "motion": "12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-google-recaptcha": "3.1.0",
    "react-icons": "5.7.0",
    "react-router": "8.1.0",
    "react-toastify": "11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-google-recaptcha": "2.1.9",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "0.28.1",
    "eslint": "9.39.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "gh-pages": "6.3.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "sass-embedded": "1.100.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
